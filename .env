# ============================================
# Frontend Environment Variables
# ============================================
# Note: Vite requires all environment variables to be prefixed with VITE_

# ============================================
# API Configuration
# ============================================
# Backend API base URL (backend runs on port 8000, frontend on port 8080)
# For local development: http://localhost:8000
# For production: Update to your production backend URL
VITE_API_BASE_URL=http://localhost:8000
# VITE_API_BASE_URL=https://sdlc.siriusai.com
# VITE_API_BASE_URL=https://sdlc-dev.deluxe.com

# ============================================
# Theme Configuration
# ============================================
# Uncomment ONE of the two lines below:
VITE_THEME=siriusai        # SiriusAI  — blue (#1B3C71) color scheme
# VITE_THEME=deluxe             # Deluxe    — red  (#D61120) color scheme

# ============================================
# Azure AD Configuration
# ============================================
VITE_AZURE_CLIENT_ID=10eda5db-4715-4e7b-bcd9-32dba3533084
VITE_AZURE_TENANT_ID=0575746d-c254-4eea-bfc6-10d0979d1e90
# ============================================
# S3 Configuration
# ============================================

# ============================================
# Vite Dev Server Proxy Configuration
# ============================================
# These are used by Vite's proxy feature (only for /api and /confluence-api routes)
# The main API calls go directly to VITE_API_BASE_URL
VITE_PROXY_API_TARGET=http://deluxe-internet-300914418.us-east-1.elb.amazonaws.com:8000
VITE_PROXY_CONFLUENCE_TARGET=https://deluxe.atlassian.net
